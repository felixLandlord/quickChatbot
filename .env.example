# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# Groq API key for LangChain
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=****

# Vercel Blob storage (optional, for file uploads)
# Get your token at: https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# Neon Postgres connection string
# Get your connection string at: https://neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
POSTGRES_URL=****

# Redis Cloud connection
# Get your connection string at: https://redis.cloud
# Format: redis://default:password@host:port
REDIS_URL=****
